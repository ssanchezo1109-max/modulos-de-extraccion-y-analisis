# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_CLIENT_ID: Derived from Google Cloud Console Credentials
# GOOGLE_CLIENT_SECRET: Derived from Google Cloud Console Credentials
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="https://your-app-url.run.app/auth/callback"
SESSION_SECRET="a-very-secret-session-key"

# TradingView Credentials (Optional: if not provided, you can pass session ID from UI)
TRADINGVIEW_USERNAME=""
TRADINGVIEW_PASSWORD=""
TRADINGVIEW_SESSION_ID=""

# Yahoo Finance Credentials
YAHOO_EMAIL=""
YAHOO_PASSWORD=""

# FreeImage.host API Key (for temporary image hosting to insert into Docs)
FREEIMAGE_API_KEY="6d207e02198a847aa98d0a2a901485a5"

# Puppeteer Evasion and Persistent Profile options
# PUPPETEER_USER_DATA_DIR: Absolute directory path to store local user session persistent data
PUPPETEER_USER_DATA_DIR="/tmp/google_profile"
# PUPPETEER_HEADLESS: Decide if Puppeteer runs headless ("true" or "new") or windowed / interactive ("false")
PUPPETEER_HEADLESS="new"

